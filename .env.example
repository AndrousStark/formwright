# Optional — the deterministic core runs WITHOUT any of these.
# Provide one to enable the LLM fallback tier (used only for genuinely ambiguous fields).

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# If using OpenAI instead:
# LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: set to "1" to enable the local embedding tier (requires @huggingface/transformers).
ENABLE_EMBEDDINGS=0
