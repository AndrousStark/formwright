{
  "name": "carrier-form-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Generalizable AI agent that fills unseen multi-page insurance web forms from an applicant JSON — deterministic-first, LLM as last resort, abstains instead of hallucinating.",
  "engines": { "node": ">=20" },
  "scripts": {
    "agent": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "fuzzball": "^2.2.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.3.0"
  }
}
